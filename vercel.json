{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/courier-site run build",
  "outputDirectory": "artifacts/courier-site/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
